# ── Manus Platform ───────────────────────────────────────────────────────────
# App ID assigned by the Manus platform — used for OAuth/auth callbacks.
# Find this value in the Manus dashboard under "App Settings".
VITE_APP_ID=

# OAuth portal base URL. For Manus-hosted apps use the default below.
VITE_OAUTH_PORTAL_URL=https://manus.computer

# ── Analytics (optional) ─────────────────────────────────────────────────────
# Self-hosted Umami analytics endpoint and site ID.
# Leave blank to disable analytics.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Maps / Frontend Forge (optional) ─────────────────────────────────────────
# API key and URL for the map component.
# Leave blank if the Map page is not used.
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
