# ── Analytics (optional) ─────────────────────────────────────────────────────
# Self-hosted Umami analytics endpoint and site ID.
# Leave blank to disable analytics.
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# ── Maps / Frontend Forge (optional) ─────────────────────────────────────────
# API key and URL for the map component.
# Leave blank if the Map page is not used.
VITE_FRONTEND_FORGE_API_KEY=
VITE_FRONTEND_FORGE_API_URL=
