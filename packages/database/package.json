{
  "name": "@naval/database",
  "version": "0.1.0",
  "private": true,
  "description": "Prisma schema, migrations, and seed data for the Naval Digital Twin Platform",
  "scripts": {
    "db:validate": "prisma validate --schema=./prisma/schema.prisma",
    "db:generate": "prisma generate --schema=./prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema=./prisma/schema.prisma",
    "db:migrate:status": "prisma migrate status --schema=./prisma/schema.prisma",
    "db:seed": "tsx ./prisma/seed.ts",
    "db:studio": "prisma studio --schema=./prisma/schema.prisma",
    "db:reset": "prisma migrate reset --schema=./prisma/schema.prisma",
    "build": "echo 'No build step for @naval/database'"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0",
    "tsx": "^4.19.1",
    "typescript": "5.6.3"
  }
}
