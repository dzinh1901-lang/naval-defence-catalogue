# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://naval:naval_dev@localhost:5432/naval_dt

# ── API ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ── Web ──────────────────────────────────────────────────────────
# Server-side API URL (used by Next.js server components — never exposed to the browser).
# Set to the internal address of the API service.
API_URL=http://localhost:4000

# Browser-side API URL (used for any client-side fetch calls).
# In most cases matches API_URL for local development.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Bearer tokens used by the web app for protected API routes.
# In local development, these default to the seeded dev sentinel token.
API_AUTH_TOKEN=dev-token
NEXT_PUBLIC_API_AUTH_TOKEN=dev-token

# ── Auth (Milestone 4) ────────────────────────────────────────────
# JWT secret — must be set in production. Min 32 characters.
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars
# Token expiry in seconds — default 604800 (7 days).
# JWT_EXPIRES_IN_SECS=604800
# Bootstrap secret for POST /api/v1/auth/token (dev/service-account use only).
# AUTH_BOOTSTRAP_SECRET=replace-with-a-strong-bootstrap-secret

# ── Storage (Milestone 3+) ───────────────────────────────────────
# S3_BUCKET=naval-dt-dev
# S3_REGION=ap-southeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
