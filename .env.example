# ── Database ─────────────────────────────────────────────────────
# PostgreSQL connection string.
# Required for API + worker in every environment. Must use postgres:// or postgresql://.
DATABASE_URL=postgresql://naval:naval_dev@localhost:5432/naval_dt

# ── API ──────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
# Comma-separated browser origins allowed to call the API directly.
# Leave empty when the API is only reached through server-side calls or an internal network.
# Example: CORS_ALLOWED_ORIGINS=https://naval.example.com,https://staging.naval.example.com
# 
# For local development, you typically don't need CORS if using the same-origin setup.
# Production domains (uncomment and adjust for production deployment):
# CORS_ALLOWED_ORIGINS=https://auren-workspace.com,https://byte.dns-parking.com,https://pixel.dns-parking.com
CORS_ALLOWED_ORIGINS=

# ── Web ──────────────────────────────────────────────────────────
# Server-side API URL (used by Next.js server components — never exposed to the browser).
# Required in staging/production. Set to the internal address of the API service.
API_URL=http://localhost:4000

# Browser-visible API URL.
# Required in staging/production. Set to the external/browser-facing API address.
NEXT_PUBLIC_API_URL=http://localhost:4000

# Either provide a pre-issued bearer token for the web server...
# API_AUTH_TOKEN=
#
# ...or allow the web server to bootstrap a server-side JWT from the API.
API_SERVICE_USER_ID=dev-user-admin
API_SERVICE_EMAIL=cmdr.lee@naval-systems.dev
API_SERVICE_ORGANIZATION_ID=dev-org
API_SERVICE_ROLE=ADMIN

# ── Auth (Milestone 4) ────────────────────────────────────────────
# JWT secret — required for all API runtimes. Min 32 characters.
JWT_SECRET=replace-with-a-strong-random-secret-min-32-chars
# Token expiry in seconds — default 28800 (8 hours).
# JWT_EXPIRES_IN_SECS=28800
# Bootstrap secret for POST /api/v1/auth/token (service-account token issuance).
# Required when the web app bootstraps its own server-side JWT in local/dev or tightly controlled environments.
AUTH_BOOTSTRAP_SECRET=replace-with-a-strong-bootstrap-secret

# Production safety switch: leave disabled by default.
# Set to true only for tightly controlled environments where bootstrap token issuance is intentionally allowed.
ALLOW_BOOTSTRAP_TOKEN_ISSUANCE=false

# This release path does not require an external OAuth/OIDC callback URL yet.
# If a real identity provider replaces bootstrap auth later, add the callback URL here
# and update docs/deployment-readiness.md before rollout.

# ── Storage (Milestone 3+) ───────────────────────────────────────
# S3_BUCKET=naval-dt-dev
# S3_REGION=ap-southeast-2
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
