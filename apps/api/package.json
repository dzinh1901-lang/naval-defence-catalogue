{
  "name": "@naval/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "start": "node ./scripts/start-production.mjs",
    "start:dev": "concurrently --kill-others-on-fail --names tsc,api --prefix-colors yellow,blue \"node ./scripts/watch-build.mjs\" \"node ./scripts/wait-for-build.mjs\"",
    "start:debug": "concurrently --kill-others-on-fail --names tsc,api --prefix-colors yellow,blue \"node ./scripts/watch-build.mjs\" \"node --inspect=0.0.0.0:9229 ./scripts/wait-for-build.mjs\"",
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "helmet": "^8.1.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^11.1.18",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/terminus": "^10.2.3",
    "@prisma/client": "^5.22.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "nestjs-pino": "^4.6.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino-http": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@naval/config": "workspace:*",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.2.3",
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/passport-jwt": "^4.0.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "typescript": "5.6.3"
  }
}
