# ── Build stage ───────────────────────────────────────────────────────────────
FROM node:20-bullseye-slim AS builder

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.4.1 --activate

COPY package.json pnpm-workspace.yaml pnpm-lock.yaml ./
COPY patches/ ./patches/
COPY scripts/startup-runtime.mjs ./scripts/
COPY packages/config/package.json ./packages/config/
COPY packages/domain/package.json ./packages/domain/
COPY packages/ui/package.json ./packages/ui/
COPY apps/web/package.json ./apps/web/

RUN pnpm install --frozen-lockfile

COPY packages/config/ ./packages/config/
COPY packages/domain/ ./packages/domain/
COPY packages/ui/ ./packages/ui/
COPY apps/web/ ./apps/web/

# Set a browser-reachable default for the client bundle; override with --build-arg in real deploy pipelines.
ARG NEXT_PUBLIC_API_URL=http://localhost:4400
ENV NEXT_PUBLIC_API_URL=${NEXT_PUBLIC_API_URL}

RUN pnpm --filter @naval/web build

# ── Production stage ───────────────────────────────────────────────────────────
FROM node:20-bullseye-slim AS runner

WORKDIR /app

ENV NODE_ENV=production
ENV PORT=3000

COPY --from=builder /app/apps/web/.next/standalone ./apps/web/.next/standalone
COPY --from=builder /app/apps/web/.next/static ./apps/web/.next/static
COPY --from=builder /app/apps/web/scripts/start-production.mjs ./apps/web/scripts/start-production.mjs
COPY --from=builder /app/scripts/startup-runtime.mjs ./scripts/startup-runtime.mjs

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=20s \
  CMD node -e "fetch('http://localhost:3000/api/health/ready').then((res) => process.exit(res.ok ? 0 : 1)).catch(() => process.exit(1))"

CMD ["node", "apps/web/scripts/start-production.mjs"]
